datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  hashedPassword     String
  fullName           String
  credits            Int                 @default(2)
  createdAt          DateTime            @default(now())
  applications       Application[]
  skills             Skill[]
  learningItems      LearningItem[]
  journalEntries     JournalEntry[]
  revisionLists      RevisionList[]
  analyticsSnapshots AnalyticsSnapshot[]
  questions          Question[]
  aiInterviews       AIInterview[]
}

model Company {
  id           String        @id @default(uuid())
  name         String        @unique
  website      String?
  applications Application[]
}

model Application {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  position    String
  salaryMin   Int?
  salaryMax   Int?
  currency    String           @default("USD")
  source      String?
  status      String           @default("Applied") // e.g. Applied, Screening, Technical, Fit, Offer, Rejected
  appliedDate DateTime
  createdAt   DateTime         @default(now())
  rounds      InterviewRound[]
}

model InterviewRound {
  id               String         @id @default(uuid())
  applicationId    String
  application      Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roundNumber      Int
  roundType        String // e.g. HR, Technical Screen, Coding, System Design, Behavioral
  interviewerNames String?
  scheduledAt      DateTime?
  durationMinutes  Int?
  status           String         @default("Scheduled") // e.g. Scheduled, Completed, Cancelled
  confidenceScore  Int? // 1 to 10
  feedbackNotes    String?
  questions        Question[]
  journalEntries   JournalEntry[]
}

model Question {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  roundId         String?
  round           InterviewRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)
  text            String
  answerDraft     String?
  difficulty      String          @default("Medium") // Easy, Medium, Hard
  category        String          @default("General") // Data Structures, System Design, etc.
  confidenceLevel Int             @default(5) // 1 to 10 scale
  needsRevision   Boolean         @default(true)
  createdAt       DateTime        @default(now())
  skills          Skill[]         @relation("QuestionSkills")
  revisionLists   RevisionList[]
}

model Skill {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  proficiencyLevel String     @default("Intermediate") // Beginner, Intermediate, Expert
  questions        Question[] @relation("QuestionSkills")

  @@unique([userId, name])
}

model RevisionList {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  priority     String   @default("Medium") // High, Medium, Low
  status       String   @default("Pending") // Pending, Completed
}

model LearningItem {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillName       String
  status          String    @default("Backlog") // Backlog, In Progress, Mastered
  progressPercent Int       @default(0) // 0 to 100
  hoursInvested   Float     @default(0.0)
  lastStudiedAt   DateTime? @default(now())
}

model JournalEntry {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewRoundId String?
  interviewRound   InterviewRound? @relation(fields: [interviewRoundId], references: [id], onDelete: SetNull)
  wins             String?
  mistakes         String?
  mood             String? // Confident, Anxious, Exhausted
  nextActions      String?
  loggedAt         DateTime        @default(now())
}

model AnalyticsSnapshot {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capturedDate      DateTime @default(now())
  readinessScore    Int      @default(0)
  totalApplications Int      @default(0)
  totalInterviews   Int      @default(0)
  conversionRate    Float    @default(0.0)
}

model AIInterview {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position        String
  companyName     String?
  jobDescription  String
  resumeText      String? // Parsed resume text
  personality     String
  overallScore    Int? // null if in progress
  verdict         String? // SELECTED or NOT SELECTED, null if in progress
  feedbackSummary String? // text description
  strengths       String? // JSON array of strings
  weaknesses      String? // JSON array of strings
  transcript      String // JSON string of messages
  createdAt       DateTime @default(now())
}
