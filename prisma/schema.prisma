datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  hashedPassword     String
  fullName           String
  credits            Int                 @default(2)
  createdAt          DateTime            @default(now())
  applications       Application[]
  skills             Skill[]
  learningItems      LearningItem[]
  journalEntries     JournalEntry[]
  revisionLists      RevisionList[]
  analyticsSnapshots AnalyticsSnapshot[]
  questions          Question[]
  aiInterviews       AIInterview[]
  weaknessProfile    WeaknessProfile?
  packAccesses       UserPackAccess[]
  scorecards         Scorecard[]
  learningPlan       LearningPlan?
}

model Company {
  id           String        @id @default(uuid())
  name         String        @unique
  website      String?
  applications Application[]
}

model Application {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  position    String
  salaryMin   Int?
  salaryMax   Int?
  currency    String           @default("USD")
  source      String?
  status      String           @default("Applied") // e.g. Applied, Screening, Technical, Fit, Offer, Rejected
  appliedDate DateTime
  createdAt   DateTime         @default(now())
  rounds      InterviewRound[]
}

model InterviewRound {
  id              String         @id @default(uuid())
  applicationId   String
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roundNumber     Int
  roundType       String         // e.g. HR, Technical Screen, Coding, System Design, Behavioral
  interviewerNames String?
  scheduledAt     DateTime?
  durationMinutes Int?
  status          String         @default("Scheduled") // e.g. Scheduled, Completed, Cancelled
  confidenceScore Int?           // 1 to 10
  feedbackNotes   String?
  questions       Question[]
  journalEntries  JournalEntry[]
}

model Question {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roundId         String?
  round           InterviewRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)
  text            String
  answerDraft     String?
  difficulty      String         @default("Medium") // Easy, Medium, Hard
  category        String         @default("General") // Data Structures, System Design, etc.
  confidenceLevel Int            @default(5) // 1 to 10 scale
  needsRevision   Boolean        @default(true)
  createdAt       DateTime       @default(now())
  skills          Skill[]        @relation("QuestionSkills")
  revisionLists   RevisionList[]
}

model Skill {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  proficiencyLevel String     @default("Intermediate") // Beginner, Intermediate, Expert
  questions        Question[] @relation("QuestionSkills")

  @@unique([userId, name])
}

model RevisionList {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  priority     String   @default("Medium") // High, Medium, Low
  status       String   @default("Pending") // Pending, Completed
}

model LearningItem {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillName       String
  status          String    @default("Backlog") // Backlog, In Progress, Mastered
  progressPercent Int       @default(0) // 0 to 100
  hoursInvested   Float     @default(0.0)
  lastStudiedAt   DateTime? @default(now())
}

model JournalEntry {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewRoundId String?
  interviewRound   InterviewRound? @relation(fields: [interviewRoundId], references: [id], onDelete: SetNull)
  wins             String?
  mistakes         String?
  mood             String?         // Confident, Anxious, Exhausted
  nextActions      String?
  loggedAt         DateTime        @default(now())
}

model AnalyticsSnapshot {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capturedDate      DateTime @default(now())
  readinessScore    Int      @default(0)
  totalApplications Int      @default(0)
  totalInterviews   Int      @default(0)
  conversionRate    Float    @default(0.0)
}

model AIInterview {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  position        String
  companyName     String?
  jobDescription  String
  resumeText      String?      // Parsed resume text
  personality     String
  overallScore    Int?         // null if in progress
  verdict         String?      // SELECTED or NOT SELECTED, null if in progress
  feedbackSummary String?      // text description
  strengths       String?      // JSON array of strings
  weaknesses      String?      // JSON array of strings
  transcript      String       // JSON string of messages
  createdAt       DateTime     @default(now())
  deletedAt       DateTime?
  voiceEnabled    Boolean      @default(false)
  packId          String?
  pack            CompanyPack? @relation(fields: [packId], references: [id], onDelete: SetNull)
  interviewType   String       @default("technical")
  scorecard       Scorecard?

  @@index([userId, createdAt])
  @@index([userId, interviewType])
  @@index([userId, overallScore])
  @@index([packId])
}

model WeaknessProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics         String     // JSON array of weak topics
  lastAnalyzedAt DateTime @default(now())
  sessionCount   Int      @default(0)

  @@index([userId])
}

model CompanyPack {
  id                       String           @id @default(uuid())
  companyName              String           @unique
  companyLogoUrl           String?
  description              String
  difficulty               String           // easy, medium, hard
  interviewType            String           // technical, behavioral, system design
  tier                     String           // free, premium
  questionFocusAreas       String             // JSON array of strings
  culturalContext          String
  estimatedDurationMinutes Int
  createdAt                DateTime         @default(now())
  aiInterviews             AIInterview[]
  userAccesses             UserPackAccess[]

  @@index([companyName])
}

model UserPackAccess {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  packId          String
  pack            CompanyPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  accessGrantedAt DateTime    @default(now())
  accessType      String      // free, purchased, subscription

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
}

model Scorecard {
  id                   String      @id @default(cuid())
  sessionId            String      @unique
  session              AIInterview @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicToken          String      @unique
  isPublic             Boolean     @default(false)
  generatedAt          DateTime    @default(now())
  expiresAt            DateTime?
  executiveSummary     String?
  strengths            String?       // JSON array of strengths
  improvements         String?       // JSON array of improvement areas
  readinessLevel       String?     // not ready, developing, interview ready, strongly recommended
  hiringRecommendation String?

  @@index([userId])
  @@index([publicToken])
}

model LearningPlan {
  id                    String    @id @default(uuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCompanies       String      // JSON array of strings
  targetRole            String
  availableHoursPerWeek Int
  interviewDate         DateTime?
  generatedPlan         String      // structured plan JSON
  generatedAt           DateTime  @default(now())
  weekStartDate         DateTime
  isActive              Boolean   @default(true)

  @@index([userId])
}
